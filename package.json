{
  "name": "@nanofreeze/coldchain-calc",
  "version": "0.2.0",
  "description": "Pure cold-chain logistics savings calculator — reduce transport waste (merma) with NanoFreeze cold layers (capas). Framework-free, tested, MIT.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "keywords": [
    "cold-chain",
    "logistics",
    "savings",
    "calculator",
    "roi",
    "refrigeration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./calc": {
      "types": "./dist/calc.d.ts",
      "import": "./dist/calc.js",
      "default": "./dist/calc.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./country": {
      "types": "./dist/country.d.ts",
      "import": "./dist/country.js",
      "default": "./dist/country.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.js",
      "default": "./dist/defaults.js"
    },
    "./input-schema": {
      "types": "./dist/input-schema.d.ts",
      "import": "./dist/input-schema.js",
      "default": "./dist/input-schema.js"
    },
    "./capas": {
      "types": "./dist/capas/index.d.ts",
      "import": "./dist/capas/index.js",
      "default": "./dist/capas/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --webpack -p 4173",
    "build": "next build --webpack",
    "start": "npx --yes serve out -l 4173",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:lib": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:lib"
  },
  "//deps": "The PUBLISHED package is the engine in dist/ — its only runtime dependency is zod. Next, React and Tailwind build the app in this repo; they are devDependencies on purpose, because `npm i @nanofreeze/coldchain-calc` must not drag a web framework into someone else's project.",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
